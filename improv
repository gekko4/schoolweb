<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="AeroBrew - AI-powered portable espresso maker for coffee anywhere.">
    <title>AeroBrew | Portable Espresso Maker</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&family=Roboto+Slab:wght@500&display=swap" rel="stylesheet">
    
    <!-- Styles -->
    <link rel="stylesheet" href="style.css">
</head>
<body id="top">

    <!-- Navigation -->
    <nav class="nav" aria-label="Main navigation">
        <a href="#top" class="logo">
            <h3>☕ AeroBrew</h3>
        </a>
        
        <div class="menu">
            <div class="links">
                <a href="#features" class="link">Features</a>
                <a href="#specs" class="link">Specs</a>
                <a href="#pre-order" class="link">Pre-Order</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="hero">
        <div class="hero-box">
            <h1 id="title" class="title fade">Barista Quality.<br>Anywhere.</h1>
            <p class="subtitle fade">
                AeroBrew is the world's first AI-powered portable espresso maker. 
                Fresh, perfect coffee on the mountain, in the office, or on the road.
            </p>
            <a href="#features" class="btn fade" role="button">Discover More</a>
        </div>
    </header>

    <main>

        <!-- Features Section -->
        <section id="features" class="features spy" aria-labelledby="features-heading">
            <h2 id="features-heading" class="visually-hidden">Product Features</h2>
            
            <article class="row">
                <div class="image">
                    <img src="images/feature-battery.png" alt="Close-up of AeroBrew battery technology" loading="lazy">
                </div>
                <div class="text">
                    <h3>All-Day Battery</h3>
                    <p>
                        Power through your day with enough juice for 15 full shots. 
                        USB-C fast charging gets you back to 100% in under an hour.
                    </p>
                </div>
            </article>

            <article id="specs" class="row reverse spy" style="scroll-margin-top: 100px;">
                <div class="image">
                    <img src="images/feature-extraction.png" alt="Espresso pouring from AeroBrew machine" loading="lazy">
                </div>
                <div class="text">
                    <h3>Smart Extraction</h3>
                    <p>
                        AeroBrew monitors temperature 100 times per second, maintaining 
                        a perfect 93°C extraction for consistent espresso quality.
                    </p>
                </div>
            </article>

            <article class="row">
                <div class="image">
                    <img src="images/feature-travel.png" alt="Portable AeroBrew in a travel backpack" loading="lazy">
                </div>
                <div class="text">
                    <h3>Built for the Road</h3>
                    <p>
                        Crafted from aerospace-grade aluminum, weighing just 1.2 lbs. 
                        Compact enough to fit in your daily carry.
                    </p>
                </div>
            </article>

        </section>

        <!-- Newsletter Section -->
        <section id="pre-order" class="newsletter spy" aria-labelledby="newsletter-heading">
            <h2 id="newsletter-heading">Join the Coffee Revolution</h2>
            <p>
                Subscribe for early-bird discounts, pre-order updates, and brewing tips.
            </p>
            
            <form class="form" id="newsletter-form">
                <label for="email" class="visually-hidden">Email address</label>
                <input 
                    type="email" 
                    id="email"
                    name="email"
                    placeholder="Enter your email address" 
                    required
                    aria-required="true"
                >
                <button type="submit">Subscribe</button>
            </form>

            <p id="form-message" aria-live="polite"></p>
        </section>

    </main>

    <!-- Footer -->
    <footer>
        <p>&copy; 2026 AeroBrew Technologies</p>
    </footer>

    <!-- Script -->
    <script src="script.js" defer></script>

</body>
</html>
